# ──────────────────────────────────────────────────────────────────────────────
# NASaAlaga - Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# On Railway: this is auto-injected when you add a PostgreSQL service
# Locally: create a PostgreSQL database and paste the connection string here
DATABASE_URL=postgresql://user:password@localhost:5432/nasaalaga

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
# In production on Railway, set this to your Railway app URL
# e.g. https://nasaalaga-production.up.railway.app
FRONTEND_URL=http://localhost:3000

# ── Email (Gmail via Nodemailer) ──────────────────────────────────────────────
# Use your Gmail address + a Gmail App Password (NOT your real Gmail password)
#
# How to get an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Create app: name it "NASaAlaga"
#   5. Copy the 16-character password and paste it below (remove spaces)
#
# Without these, OTP emails won't send but a fallback code will be shown
# in the backend console and API response (development mode only).
GMAIL_USER=veterinaryofficec@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password-here

# ── Frontend Env (Vite) ───────────────────────────────────────────────────────
# Only needed if frontend is deployed separately from backend
# Leave empty when both are served from the same Railway service
VITE_API_URL=
