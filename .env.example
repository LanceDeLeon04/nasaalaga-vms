# ──────────────────────────────────────────────────────────────────────────────
# NASaAlaga - Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# On Railway: this is auto-injected when you add a PostgreSQL service
# Locally: create a PostgreSQL database and paste the connection string here
DATABASE_URL=postgresql://user:password@localhost:5432/nasaalaga

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── Frontend URL (CORS) ───────────────────────────────────────────────────────
# In production on Railway, set this to your Railway app URL
# e.g. https://nasaalaga-production.up.railway.app
FRONTEND_URL=http://localhost:3000

# ── Email (Optional - Brevo / Sendinblue) ─────────────────────────────────────
# Get a free API key at https://brevo.com
# Without this, OTP will be shown in fallback mode (console/UI) during dev
BREVO_API_KEY=

# ── Frontend Env (Vite) ───────────────────────────────────────────────────────
# Only needed if frontend is deployed separately from backend
# Leave empty when both are served from the same Railway service
VITE_API_URL=
